# OVERLAY

def draw_minimal_overlay(frame, lines):
    out = frame.copy()

    font = cv2.FONT_HERSHEY_SIMPLEX
    fs = 0.70
    th = 2
    x, y0, dy = 20, 35, 30

    max_w = 0
    for line in lines:
        (w, _), _ = cv2.getTextSize(line, font, fs, th)
        max_w = max(max_w, w)

    cv2.rectangle(out, (10, 10), (max_w + 40, y0 + dy * len(lines)), (0, 0, 0), -1)

    for i, line in enumerate(lines):
        cv2.putText(out, line, (x, y0 + i*dy), font, fs, (255, 255, 255), th, cv2.LINE_AA)

    return out


# CAMERA SETUP + FOCUS LOCK COPIED FROM amen.py STYLE

def open_camera_and_lock_focus():
    print("[INFO] Opening CSI camera using GStreamer...", flush=True)

    cap = cv2.VideoCapture(GST_PIPELINE, cv2.CAP_GSTREAMER)
    if not cap.isOpened():
        raise RuntimeError("Could not open CSI camera using GStreamer.")

    if USE_FOCUSER:
        if not HAS_FOCUSER:
            print("[WARN] USE_FOCUSER=True but Focuser.py could not be imported.", flush=True)
        else:
            print(f"[INFO] Setting fixed focus on I2C bus {I2C_BUS} to {FIXED_FOCUS}...", flush=True)

            focuser = Focuser(I2C_BUS)

            for i in range(FOCUS_COMMAND_REPEATS):
                focuser.set(Focuser.OPT_FOCUS, FIXED_FOCUS)
                print(f"[INFO] Focus command {i + 1}/{FOCUS_COMMAND_REPEATS} sent: {FIXED_FOCUS}", flush=True)
                time.sleep(0.1)

            print(f"[INFO] Focus set to {FIXED_FOCUS}, waiting for lens to settle...", flush=True)

            settle_start = time.time()
            settle_frames = 0

            while time.time() - settle_start < FOCUS_SETTLE_SEC:
                ret, frame = cap.read()
                if not ret:
                    raise RuntimeError("Camera stream failed during focus settling.")

                settle_frames += 1

                if SHOW_PREVIEW:
                    cv2.imshow("Video Feed", frame)
                    cv2.waitKey(1)

            print(
                f"[INFO] Focus locked at {FIXED_FOCUS} "
                f"(drained {settle_frames} frames over {FOCUS_SETTLE_SEC}s)",
                flush=True
            )

    return cap


