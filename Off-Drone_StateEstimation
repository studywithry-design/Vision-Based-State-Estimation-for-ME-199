# SHARED CAMERA BUFFER THREAD

class LatestFrameBuffer:


    def __init__(self, cap, output_dir: Path):
        self.output_dir = output_dir

        self.cap = cap
        self.writer = None

        self.lock = threading.Lock()
        self.latest_frame = None
        self.latest_index = -1
        self.latest_time = 0.0

        self.frame_count = 0
        self.running = False
        self.start_time = None

        self.temp_video_path = output_dir / RAW_TEMP_VIDEO_NAME
        self.final_video_path = output_dir / RAW_FINAL_VIDEO_NAME
        self.frame_map_path = output_dir / FRAME_MAP_CSV_NAME
        self.written_frame_count = 0
        self.first_frame_time = None
        self.last_frame_time = None

    def start(self):
        if SAVE_RAW_VIDEO:
            self.writer = cv2.VideoWriter(
                str(self.temp_video_path),
                cv2.VideoWriter_fourcc(*"mp4v"),
                FRAMERATE,
                (WIDTH, HEIGHT)
            )
            if not self.writer.isOpened():
                raise RuntimeError(f"Could not open raw video writer: {self.temp_video_path}")

            write_frame_map_header(self.frame_map_path)

        self.running = True
        self.start_time = time.time()

        self.thread = threading.Thread(target=self._loop, daemon=True)
        self.thread.start()

    def _loop(self):
        while self.running:
            ret, frame = self.cap.read()
            if not ret:
                continue

            t = time.time() - self.start_time

            if self.writer is not None:
                self.writer.write(frame)
                append_frame_map_row(self.frame_map_path, self.frame_count, t, time.time())
                self.written_frame_count += 1
                if self.first_frame_time is None:
                    self.first_frame_time = t
                self.last_frame_time = t

            with self.lock:
                self.latest_frame = frame
                self.latest_index = self.frame_count
                self.latest_time = t

            self.frame_count += 1

    def get_latest(self):
        with self.lock:
            if self.latest_frame is None:
                return None, -1, 0.0

            return self.latest_frame.copy(), self.latest_index, self.latest_time

    def stop(self):
        self.running = False

        if hasattr(self, "thread"):
            self.thread.join(timeout=2.0)

        if self.writer is not None:
            self.writer.release()

        if self.cap is not None:
            self.cap.release()

        elapsed = time.time() - self.start_time if self.start_time else 0.0
        measured_fps_loop = self.frame_count / elapsed if elapsed > 0 else 0.0

        if self.first_frame_time is not None and self.last_frame_time is not None and self.last_frame_time > self.first_frame_time:
            measured_fps_written = max(1.0, (self.written_frame_count - 1) / (self.last_frame_time - self.first_frame_time))
        else:
            measured_fps_written = measured_fps_loop

        measured_fps = measured_fps_written

        print(f"[INFO] Capture loop FPS estimate: {measured_fps_loop:.3f}", flush=True)
        print(f"[INFO] Video written FPS estimate: {measured_fps_written:.3f}", flush=True)
        print(f"[INFO] Raw video frame map: {self.frame_map_path}", flush=True)

        if SAVE_RAW_VIDEO:
            rewrite_video_with_measured_fps(
                self.temp_video_path,
                self.final_video_path,
                measured_fps
            )

        return measured_fps


# OUTPUT FOLDER

def safe_name(name: str) -> str:
    name = name.strip().replace("/", "_").replace("\\", "_")
    return re.sub(r"[^A-Za-z0-9_.-]+", "_", name) or "realtime_modelB_run"


def get_script_dir() -> Path:
    try:
        return Path(__file__).resolve().parent
    except NameError:
        return Path.cwd()


def get_output_dir() -> Path:
    script_dir = get_script_dir()

    if len(sys.argv) >= 2:
        folder_name = safe_name(sys.argv[1])
    else:
        folder_name = safe_name(input("Enter output folder name: ").strip())

    outdir = script_dir / folder_name
    outdir.mkdir(parents=True, exist_ok=True)
    return outdir


# MAIN

def main():
    output_dir = get_output_dir()
    csv_path = output_dir / CSV_NAME

    print("=" * 60, flush=True)
    print("MODEL B LOW-LATENCY REALTIME PIPELINE + 5-TAB TWIST + KALMAN — FOCUS FIXED", flush=True)
    print(f"Output folder: {output_dir}", flush=True)
    print(f"Model path: {MODEL_PATH}", flush=True)
    print(f"P matrix path: {P_MATRIX_PATH}", flush=True)
    print("=" * 60, flush=True)

    P = np.loadtxt(P_MATRIX_PATH).astype(float)
    if P.shape != (3, 4):
        raise ValueError(f"P matrix must be 3x4. Got {P.shape}")

    C_cam = camera_center_from_P(P)
    print(f"[INFO] Camera center from P: {C_cam}", flush=True)

    cap = open_camera_and_lock_focus()

    spi0 = open_encoder(ENCODER0_CS)
    spi1 = open_encoder(ENCODER1_CS)
    zero0, zero1 = zero_encoders(spi0, spi1)

    print("[INFO] Loading YOLO model...", flush=True)
    model = YOLO(MODEL_PATH, task="pose")

    try:
        model.to("cuda")
        device_arg = "cuda"
        print("[INFO] YOLO using CUDA", flush=True)
    except Exception:
        device_arg = None
        print("[WARN] Could not force CUDA. Using default device.", flush=True)

    write_csv_header(csv_path)

    annotated_writer = None
    annotated_video_path = output_dir / ANNOTATED_VIDEO_NAME
    frames_dir = output_dir / INFERENCE_FRAMES_DIR_NAME
    if SAVE_ANNOTATED_VIDEO:


        annotated_writer = cv2.VideoWriter(
            str(annotated_video_path),
            cv2.VideoWriter_fourcc(*"mp4v"),
            max(1.0, FRAMERATE / max(1, INFER_EVERY_N_CAPTURED_FRAMES)),
            (WIDTH, HEIGHT),
        )
        if not annotated_writer.isOpened():
            raise RuntimeError(f"Could not open annotated video writer: {annotated_video_path}")

    if SAVE_INFERENCE_FRAMES:
        frames_dir.mkdir(parents=True, exist_ok=True)

    buffer = LatestFrameBuffer(cap, output_dir)
    buffer.start()

    print("[INFO] Realtime started. Press ESC to stop.", flush=True)

    last_processed_frame_idx = -1
    saved_index = 0
    last_valid = None
    inference_counter = 0
    inference_start = time.time()
    twist_zero_offset = None


    kf = RealtimeSwingTwistKF()
    last_kf_time = None

    try:
        while True:
            frame, frame_idx, frame_time = buffer.get_latest()

            if frame is None:
                time.sleep(0.005)
                continue

            if frame_idx == last_processed_frame_idx:
                time.sleep(0.001)
                continue


            if frame_idx % INFER_EVERY_N_CAPTURED_FRAMES != 0:
                if SHOW_PREVIEW:
                    display = frame

                    if last_valid is not None and DRAW_OVERLAY:
                        display = draw_minimal_overlay(display, [
                            f"Model B | latest frame={frame_idx}",
                            f"Last XYZ: X={last_valid['vision_X_mm']:+.1f}, Y={last_valid['vision_Y_mm']:+.1f}, Z={last_valid['vision_Z_mm']:+.1f} mm",
                            f"Last angles: s1={last_valid['vision_swing_angle_1_deg']:+.2f}, s2={last_valid['vision_swing_angle_2_deg']:+.2f} deg",
                            f"Last twist: raw={last_valid.get('twist_deg_zeroed', np.nan):+.2f}, KF={last_valid.get('kf_twist_deg', np.nan):+.2f} deg",
                        ])

                    cv2.imshow("Realtime Model B", display)

                    if (cv2.waitKey(1) & 0xFF) == 27:
                        print("[INFO] ESC pressed.", flush=True)
                        break

                last_processed_frame_idx = frame_idx
                continue

            last_processed_frame_idx = frame_idx

            t0_infer = time.time()

            raw0 = read_angle_raw_deg(spi0)
            raw1 = read_angle_raw_deg(spi1)

            s1 = angle_diff_deg(raw0, zero0)
            s2 = angle_diff_deg(raw1, zero1)

            row = {k: np.nan for k in HEADER}
            row.update({
                "saved_index": saved_index,
                "source_frame_index": frame_idx,
                "elapsed_s": frame_time,

                "detected": 0,

                "encoder0_raw_deg": raw0,
                "encoder1_raw_deg": raw1,
                "encoder0_zero_offset_deg": zero0,
                "encoder1_zero_offset_deg": zero1,

                "swing_angle_1_deg": s1,
                "swing_angle_2_deg": s2,

                "camera_center_X_mm": C_cam[0],
                "camera_center_Y_mm": C_cam[1],
                "camera_center_Z_mm": C_cam[2],

                "error_msg": "",
            })

            display = frame.copy()

            try:
                kwargs = dict(
                    source=frame,
                    task="pose",
                    conf=YOLO_CONF_THRESHOLD,
                    imgsz=YOLO_IMGSZ,
                    save=False,
                    verbose=False,
                )

                if device_arg is not None:
                    kwargs["device"] = device_arg

                result = model.predict(**kwargs)[0]

                if result.keypoints is None or len(result.keypoints.xy) == 0:
                    raise RuntimeError("No YOLO pose detection")

                if result.boxes is not None and len(result.boxes) > 0:
                    confs = result.boxes.conf.cpu().numpy()
                    best = int(np.argmax(confs))
                    row["box_conf"] = float(confs[best])
                else:
                    best = 0

                kxy = result.keypoints.xy.cpu().numpy()[best]

                if result.keypoints.conf is not None:
                    kc = result.keypoints.conf.cpu().numpy()[best]
                else:
                    kc = np.full((kxy.shape[0],), np.nan)

                needed_indices = [CENTER_KP_INDEX] + list(TAB_KP_INDICES)
                if kxy.shape[0] <= max(needed_indices):
                    raise RuntimeError("YOLO result has fewer keypoints than kp1-kp6")

                u = float(kxy[CENTER_KP_INDEX, 0])
                v = float(kxy[CENTER_KP_INDEX, 1])
                kconf = float(kc[CENTER_KP_INDEX]) if len(kc) > CENTER_KP_INDEX else np.nan

                if not np.isfinite(u) or not np.isfinite(v):
                    raise RuntimeError("center keypoint NaN")

                if np.isfinite(kconf) and kconf < KP_CONF_THRESHOLD:
                    raise RuntimeError("center keypoint confidence below threshold")

                tab_uvs = {}
                tab_weights = {}
                keypoint_log = {
                    "kp1_x": u,
                    "kp1_y": v,
                    "kp1_conf": kconf,
                }

                for tab_idx in TAB_KP_INDICES:
                    kp_num = tab_idx + 1
                    uu = float(kxy[tab_idx, 0])
                    vv = float(kxy[tab_idx, 1])
                    cc = float(kc[tab_idx]) if len(kc) > tab_idx else np.nan

                    keypoint_log[f"kp{kp_num}_x"] = uu
                    keypoint_log[f"kp{kp_num}_y"] = vv
                    keypoint_log[f"kp{kp_num}_conf"] = cc

                    if not np.isfinite(uu) or not np.isfinite(vv):
                        continue
                    if np.isfinite(cc) and cc < KP_CONF_THRESHOLD:
                        continue

                    tab_uvs[tab_idx] = (uu, vv)
                    tab_weights[tab_idx] = cc if np.isfinite(cc) else 1.0

                if len(tab_uvs) == 0:
                    raise RuntimeError("No valid tab keypoints kp2-kp6 for twist")

                encoder_xyz, sphere_center, sphere_radius = encoder_xyz_model_B(s1, s2)

                C_ray, d_ray = pixel_to_ray_from_P(P, u, v, C_cam=C_cam)
                vision_xyz, sphere_err = intersect_ray_sphere(C_ray, d_ray, sphere_center, sphere_radius)

                if vision_xyz is None:
                    raise RuntimeError(sphere_err)

                vs1, vs2 = xyz_to_angles_B(vision_xyz)

                diff = vision_xyz - encoder_xyz
                err3 = float(np.linalg.norm(diff))

                twist, twist_err = compute_twist_from_center_and_tabs(
                    P=P,
                    C_cam=C_cam,
                    center_uv=(u, v),
                    tab_uvs=tab_uvs,
                    tab_weights=tab_weights,
                    sphere_center=sphere_center,
                    sphere_radius=sphere_radius,
                    reference=TWIST_REFERENCE,
                )
                if twist is None:
                    raise RuntimeError(twist_err)

                if twist_zero_offset is None and np.isfinite(twist["twist_deg_raw"]):
                    twist_zero_offset = float(twist["twist_deg_raw"])

                twist_zeroed = wrap_deg(float(twist["twist_deg_raw"]) - float(twist_zero_offset))

                latency_ms = (time.time() - t0_infer) * 1000.0


                current_kf_time = float(frame_time)
                if last_kf_time is None:
                    dt_kf = KF_DEFAULT_DT
                else:
                    dt_kf = current_kf_time - last_kf_time
                last_kf_time = current_kf_time
                dt_kf = float(np.clip(dt_kf, KF_MIN_DT, KF_MAX_DT))

                kf_state = kf.step(
                    dt=dt_kf,
                    measurement_available=True,
                    raw_s1=vs1,
                    raw_s2=vs2,
                    raw_twist=twist_zeroed,
                )

                inference_counter += 1
                infer_elapsed = time.time() - inference_start
                infer_fps = inference_counter / infer_elapsed if infer_elapsed > 0 else 0.0
                capture_fps = buffer.frame_count / (time.time() - buffer.start_time) if buffer.start_time else 0.0

                per_tab_log = {}
                for tab_idx, tab_data in twist["per_tab"].items():
                    kp_num = tab_idx + 1
                    per_tab_log[f"kp{kp_num}_twist_deg"] = tab_data["twist_deg"]
                    per_tab_log[f"kp{kp_num}_tab_X_mm"] = tab_data["tab_X_mm"]
                    per_tab_log[f"kp{kp_num}_tab_Y_mm"] = tab_data["tab_Y_mm"]
                    per_tab_log[f"kp{kp_num}_tab_Z_mm"] = tab_data["tab_Z_mm"]
                    per_tab_log[f"kp{kp_num}_vtab_x"] = tab_data["vtab_x"]
                    per_tab_log[f"kp{kp_num}_vtab_y"] = tab_data["vtab_y"]
                    per_tab_log[f"kp{kp_num}_vtab_z"] = tab_data["vtab_z"]

                row.update({
                    "detected": 1,

                    **keypoint_log,
                    **per_tab_log,
                    **kf_state,

                    "twist_reference_used": twist["twist_reference_used"],
                    "twist_deg_raw": twist["twist_deg_raw"],
                    "twist_deg_zeroed": twist_zeroed,
                    "twist_zero_offset_deg": twist_zero_offset,
                    "twist_num_tabs_used": twist["twist_num_tabs_used"],
                    "twist_resultant_strength": twist["twist_resultant_strength"],
                    "twist_center_X_mm": twist["twist_center_X_mm"],
                    "twist_center_Y_mm": twist["twist_center_Y_mm"],
                    "twist_center_Z_mm": twist["twist_center_Z_mm"],
                    "rhat_x": twist["rhat_x"],
                    "rhat_y": twist["rhat_y"],
                    "rhat_z": twist["rhat_z"],
                    "theta_hat_x": twist["theta_hat_x"],
                    "theta_hat_y": twist["theta_hat_y"],
                    "theta_hat_z": twist["theta_hat_z"],
                    "phi_hat_x": twist["phi_hat_x"],
                    "phi_hat_y": twist["phi_hat_y"],
                    "phi_hat_z": twist["phi_hat_z"],
                    "rotated_theta_deg": twist["rotated_theta_deg"],
                    "rotated_phi_deg": twist["rotated_phi_deg"],

                    "encoder_X_mm": encoder_xyz[0],
                    "encoder_Y_mm": encoder_xyz[1],
                    "encoder_Z_mm": encoder_xyz[2],

                    "vision_X_mm": vision_xyz[0],
                    "vision_Y_mm": vision_xyz[1],
                    "vision_Z_mm": vision_xyz[2],

                    "vision_swing_angle_1_deg": vs1,
                    "vision_swing_angle_2_deg": vs2,

                    "swing_angle_1_error_deg": vs1 - s1,
                    "swing_angle_2_error_deg": vs2 - s2,

                    "vision_encoder_error_3D_mm": err3,

                    "sphere_center_X_mm": sphere_center[0],
                    "sphere_center_Y_mm": sphere_center[1],
                    "sphere_center_Z_mm": sphere_center[2],
                    "sphere_radius_mm": sphere_radius,

                    "capture_fps_estimate": capture_fps,
                    "inference_fps_estimate": infer_fps,
                    "latency_ms": latency_ms,
                })

                last_valid = row.copy()

                if DRAW_OVERLAY:
                    center_pt = (int(round(u)), int(round(v)))
                    cv2.circle(display, center_pt, 8, (255, 255, 255), -1, cv2.LINE_AA)
                    cv2.circle(display, center_pt, 12, (0, 0, 0), 2, cv2.LINE_AA)

                    for tab_idx, (uu, vv) in tab_uvs.items():
                        tab_pt = (int(round(uu)), int(round(vv)))
                        cv2.circle(display, tab_pt, 5, (255, 255, 255), -1, cv2.LINE_AA)
                        cv2.circle(display, tab_pt, 8, (0, 0, 0), 2, cv2.LINE_AA)
                        cv2.line(display, center_pt, tab_pt, (255, 255, 255), 1, cv2.LINE_AA)

            except Exception as e:
                row["error_msg"] = str(e)


                current_kf_time = float(frame_time)
                if last_kf_time is None:
                    dt_kf = KF_DEFAULT_DT
                else:
                    dt_kf = current_kf_time - last_kf_time
                last_kf_time = current_kf_time
                dt_kf = float(np.clip(dt_kf, KF_MIN_DT, KF_MAX_DT))

                kf_state = kf.step(
                    dt=dt_kf,
                    measurement_available=False,
                )
                row.update(kf_state)

            append_csv_row(csv_path, row)
            saved_index += 1

            if SHOW_PREVIEW:
                if last_valid is not None and DRAW_OVERLAY:
                    display = draw_minimal_overlay(display, [
                        f"Model B | capFPS={row.get('capture_fps_estimate', np.nan):.1f} infFPS={row.get('inference_fps_estimate', np.nan):.1f}",
                        f"Vision XYZ: X={last_valid['vision_X_mm']:+.1f}, Y={last_valid['vision_Y_mm']:+.1f}, Z={last_valid['vision_Z_mm']:+.1f} mm",
                        f"Vision angle: s1={last_valid['vision_swing_angle_1_deg']:+.2f}, s2={last_valid['vision_swing_angle_2_deg']:+.2f} deg",
                        f"Twist: raw={last_valid.get('twist_deg_raw', np.nan):+.2f}, zeroed={last_valid.get('twist_deg_zeroed', np.nan):+.2f}, KF={last_valid.get('kf_twist_deg', np.nan):+.2f} deg",
                        f"Encoder angle: s1={s1:+.2f}, s2={s2:+.2f} deg",
                        f"3D err={last_valid['vision_encoder_error_3D_mm']:.1f} mm latency={last_valid['latency_ms']:.1f} ms",
                    ])
                else:
                    display = draw_minimal_overlay(display, [
                        "Model B",
                        f"Status: {row.get('error_msg', 'waiting')}",
                    ])

                if SAVE_ANNOTATED_VIDEO and annotated_writer is not None:
                    annotated_writer.write(display)

                if SAVE_INFERENCE_FRAMES:
                    cv2.imwrite(str(frames_dir / f"infer_{saved_index:06d}_src_{frame_idx:06d}.jpg"), display)

                cv2.imshow("Realtime Model B", display)

                if (cv2.waitKey(1) & 0xFF) == 27:
                    print("[INFO] ESC pressed.", flush=True)
                    break

    except KeyboardInterrupt:
        print("[INFO] Ctrl+C received.", flush=True)

    finally:
        measured_capture_fps = buffer.stop()

        if annotated_writer is not None:
            annotated_writer.release()

        try:
            spi0.close()
            spi1.close()
        except Exception:
            pass

        cv2.destroyAllWindows()

    print("\n================ DONE ================", flush=True)
    print(f"CSV saved to: {csv_path}", flush=True)
    print(f"Raw video saved to: {output_dir / RAW_FINAL_VIDEO_NAME}", flush=True)
    print(f"Raw video frame map saved to: {output_dir / FRAME_MAP_CSV_NAME}", flush=True)
    if SAVE_ANNOTATED_VIDEO:
        print(f"Annotated inference video saved to: {annotated_video_path}", flush=True)
    if SAVE_INFERENCE_FRAMES:
        print(f"Inference frames saved to: {frames_dir}", flush=True)
    print(f"Measured capture FPS: {measured_capture_fps:.2f}", flush=True)
    print("======================================", flush=True)


