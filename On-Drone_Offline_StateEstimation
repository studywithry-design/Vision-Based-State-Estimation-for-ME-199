def find_image_for_row(trial_dir: Path, images_dir: Path, old_row: dict):
    rel = old_row.get("matched_image_path", "")
    if rel:
        p = trial_dir / rel
        if p.exists():
            return p
        p2 = Path(rel)
        if p2.exists():
            return p2
        p3 = images_dir / Path(rel).name
        if p3.exists():
            return p3


    saved_index = as_int(old_row.get("saved_index"), default=-1)
    if saved_index >= 0:
        matches = sorted(images_dir.glob(f"csv_{saved_index:06d}_*.jpg"))
        if matches:
            return matches[0]


    frame_idx = as_int(old_row.get("source_frame_index"), default=-1)
    if frame_idx >= 0:
        matches = sorted(images_dir.glob(f"*frame_{frame_idx:06d}_*.jpg"))
        if matches:
            return matches[0]

    return None


