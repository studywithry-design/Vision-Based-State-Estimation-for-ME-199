def resolve_path(user_text: str, base_dirs):

    p = Path(user_text.strip().strip('"').strip("'"))
    if p.exists():
        return p.resolve()
    for base in base_dirs:
        q = Path(base) / p
        if q.exists():
            return q.resolve()
    return p


