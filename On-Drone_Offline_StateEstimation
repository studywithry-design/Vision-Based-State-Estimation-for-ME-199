    s2 = as_float(old_row.get("swing_angle_2_deg"))

    row.update({
        "saved_index": as_int(old_row.get("saved_index"), processed_count),
        "source_frame_index": as_int(old_row.get("source_frame_index"), -1),
        "elapsed_s": elapsed_s,
        "detected": 0,
        "encoder0_raw_deg": as_float(old_row.get("encoder0_raw_deg")),
        "encoder1_raw_deg": as_float(old_row.get("encoder1_raw_deg")),
        "encoder0_zero_offset_deg": as_float(old_row.get("encoder0_zero_offset_deg")),
        "encoder1_zero_offset_deg": as_float(old_row.get("encoder1_zero_offset_deg")),
        "swing_angle_1_deg": s1,
        "swing_angle_2_deg": s2,
        "camera_center_X_mm": C_cam[0],
        "camera_center_Y_mm": C_cam[1],
        "camera_center_Z_mm": C_cam[2],
        "matched_image_path": str(Path(MATCHED_IMAGES_DIR_NAME) / img_path.name),
        "error_msg": "",
    })


    if last_kf_time_ref[0] is None or not np.isfinite(elapsed_s):
        dt_kf = KF_DEFAULT_DT
    else:
        dt_kf = elapsed_s - last_kf_time_ref[0]
    if np.isfinite(elapsed_s):
        last_kf_time_ref[0] = elapsed_s
    dt_kf = float(np.clip(dt_kf, KF_MIN_DT, KF_MAX_DT))

    t0 = time.time()
    annotated = None

    try:
        img = cv2.imread(str(img_path))
        if img is None:
            raise RuntimeError(f"Could not read image: {img_path}")

        kwargs = dict(
            source=img,
            task="pose",
            conf=YOLO_CONF_THRESHOLD,
            imgsz=YOLO_IMGSZ,
            save=False,
            verbose=False,
        )
        if device_arg is not None:
            kwargs["device"] = device_arg
        result = model.predict(**kwargs)[0]
        annotated = result.plot()

        if result.keypoints is None or len(result.keypoints.xy) == 0:
            raise RuntimeError("No offline YOLO pose detection")

        if result.boxes is not None and len(result.boxes) > 0:
            confs = result.boxes.conf.cpu().numpy()
            best = int(np.argmax(confs))
            row["box_conf"] = float(confs[best])
        else:
            best = 0

        kxy = result.keypoints.xy.cpu().numpy()[best]
        if result.keypoints.conf is not None:
            kc = result.keypoints.conf.cpu().numpy()[best]
        else:
            kc = np.full((kxy.shape[0],), np.nan)

        needed_indices = [CENTER_KP_INDEX] + list(TAB_KP_INDICES)
        if kxy.shape[0] <= max(needed_indices):
            raise RuntimeError("YOLO result has fewer keypoints than kp1-kp6")


        for py_idx in range(NUM_KEYPOINTS):
            kp_num = py_idx + 1
            row[f"kp{kp_num}_x"] = float(kxy[py_idx, 0])
            row[f"kp{kp_num}_y"] = float(kxy[py_idx, 1])
            row[f"kp{kp_num}_conf"] = float(kc[py_idx]) if len(kc) > py_idx else np.nan

        u = as_float(row["kp1_x"])
        v = as_float(row["kp1_y"])
        kconf = as_float(row["kp1_conf"])

        if not np.isfinite(u) or not np.isfinite(v):
            raise RuntimeError("center keypoint NaN")
        if np.isfinite(kconf) and kconf < KP_CONF_THRESHOLD:
            raise RuntimeError("center keypoint confidence below threshold")

        tab_uvs = {}
        tab_weights = {}
        for tab_idx in TAB_KP_INDICES:
            kp_num = tab_idx + 1
            uu = as_float(row[f"kp{kp_num}_x"])
            vv = as_float(row[f"kp{kp_num}_y"])
            cc = as_float(row[f"kp{kp_num}_conf"])
            if not np.isfinite(uu) or not np.isfinite(vv):
                continue
            if np.isfinite(cc) and cc < KP_CONF_THRESHOLD:
                continue
            tab_uvs[tab_idx] = (uu, vv)
            tab_weights[tab_idx] = cc if np.isfinite(cc) else 1.0

        if len(tab_uvs) == 0:
            raise RuntimeError("No valid tab keypoints kp2-kp6 for twist")
        if not np.isfinite(s1) or not np.isfinite(s2):
            raise RuntimeError("Missing saved encoder swing_angle_1_deg/swing_angle_2_deg in realtime CSV")

        encoder_xyz, sphere_center, sphere_radius = encoder_xyz_model_B(s1, s2)

        C_ray, d_ray = pixel_to_ray_from_P(P, u, v, C_cam=C_cam)
        vision_xyz, sphere_err = intersect_ray_sphere(C_ray, d_ray, sphere_center, sphere_radius)
        if vision_xyz is None:
            raise RuntimeError(sphere_err)

        vs1, vs2 = xyz_to_angles_B(vision_xyz)
        err3 = float(np.linalg.norm(vision_xyz - encoder_xyz))

        twist, twist_err = compute_twist_from_center_and_tabs(
            P=P,
            C_cam=C_cam,
            center_uv=(u, v),
            tab_uvs=tab_uvs,
            tab_weights=tab_weights,
            sphere_center=sphere_center,
            sphere_radius=sphere_radius,
            reference=TWIST_REFERENCE,
        )
        if twist is None:
            raise RuntimeError(twist_err)


        if twist_zero_state["offset"] is None and np.isfinite(twist["twist_deg_raw"]):
            twist_zero_state["buffer"].append(float(twist["twist_deg_raw"]))
            if len(twist_zero_state["buffer"]) >= TWIST_ZERO_SAMPLES:

                twist_zero_state["offset"] = float(np.mean(twist_zero_state["buffer"]))

        if twist_zero_state["offset"] is not None:
            twist_zeroed = wrap_deg(float(twist["twist_deg_raw"]) - float(twist_zero_state["offset"]))
        else:
            twist_zeroed = np.nan

        kf_measurement_available = np.isfinite(vs1) and np.isfinite(vs2) and np.isfinite(twist_zeroed)
        kf_state = kf.step(dt=dt_kf, measurement_available=kf_measurement_available, raw_s1=vs1, raw_s2=vs2, raw_twist=twist_zeroed)

        per_tab_log = {}
        for tab_idx, tab_data in twist["per_tab"].items():
            kp_num = tab_idx + 1
            per_tab_log[f"kp{kp_num}_twist_deg"] = tab_data["twist_deg"]
            per_tab_log[f"kp{kp_num}_tab_X_mm"] = tab_data["tab_X_mm"]
            per_tab_log[f"kp{kp_num}_tab_Y_mm"] = tab_data["tab_Y_mm"]
            per_tab_log[f"kp{kp_num}_tab_Z_mm"] = tab_data["tab_Z_mm"]
            per_tab_log[f"kp{kp_num}_vtab_x"] = tab_data["vtab_x"]
            per_tab_log[f"kp{kp_num}_vtab_y"] = tab_data["vtab_y"]
            per_tab_log[f"kp{kp_num}_vtab_z"] = tab_data["vtab_z"]

        infer_elapsed = time.time() - start_time_process
        inference_fps = (processed_count + 1) / infer_elapsed if infer_elapsed > 0 else 0.0

        row.update({
            "detected": 1,
            **per_tab_log,
            **kf_state,
            "twist_reference_used": twist["twist_reference_used"],
            "twist_deg_raw": twist["twist_deg_raw"],
            "twist_deg_zeroed": twist_zeroed,
            "twist_zero_offset_deg": twist_zero_state["offset"],
            "twist_num_tabs_used": twist["twist_num_tabs_used"],
            "twist_resultant_strength": twist["twist_resultant_strength"],
            "twist_center_X_mm": twist["twist_center_X_mm"],
            "twist_center_Y_mm": twist["twist_center_Y_mm"],
            "twist_center_Z_mm": twist["twist_center_Z_mm"],
            "rhat_x": twist["rhat_x"], "rhat_y": twist["rhat_y"], "rhat_z": twist["rhat_z"],
            "theta_hat_x": twist["theta_hat_x"], "theta_hat_y": twist["theta_hat_y"], "theta_hat_z": twist["theta_hat_z"],
            "phi_hat_x": twist["phi_hat_x"], "phi_hat_y": twist["phi_hat_y"], "phi_hat_z": twist["phi_hat_z"],
            "rotated_theta_deg": twist["rotated_theta_deg"],
            "rotated_phi_deg": twist["rotated_phi_deg"],
            "encoder_X_mm": encoder_xyz[0],
            "encoder_Y_mm": encoder_xyz[1],
            "encoder_Z_mm": encoder_xyz[2],
            "vision_X_mm": vision_xyz[0],
            "vision_Y_mm": vision_xyz[1],
            "vision_Z_mm": vision_xyz[2],
            "vision_swing_angle_1_deg": vs1,
            "vision_swing_angle_2_deg": vs2,
            "swing_angle_1_error_deg": vs1 - s1,
            "swing_angle_2_error_deg": vs2 - s2,
            "vision_encoder_error_3D_mm": err3,
            "sphere_center_X_mm": sphere_center[0],
            "sphere_center_Y_mm": sphere_center[1],
            "sphere_center_Z_mm": sphere_center[2],
            "sphere_radius_mm": sphere_radius,
            "capture_fps_estimate": as_float(old_row.get("capture_fps_estimate")),
            "inference_fps_estimate": inference_fps,
            "latency_ms": (time.time() - t0) * 1000.0,
        })

    except Exception as e:
        row["error_msg"] = str(e)
        kf_state = kf.step(dt=dt_kf, measurement_available=False)
        row.update(kf_state)
        if annotated is None:
            img = cv2.imread(str(img_path))
            annotated = img if img is not None else np.zeros((720, 1280, 3), dtype=np.uint8)

    annotated = draw_text_overlay(annotated, row)
    return row, annotated


def main():
    script_dir = Path(__file__).resolve().parent

    print("\n=== OFFLINE MODEL B REPROCESSOR FROM state(6).py ===\n")

    trial_text = input("Paste REALTIME TRIAL FOLDER path: \n> ").strip().strip('"').strip("'")
    trial_dir = Path(trial_text).expanduser().resolve()
    if not trial_dir.exists():
        raise FileNotFoundError(f"Trial folder not found: {trial_dir}")

    realtime_csv_path = trial_dir / REALTIME_CSV_NAME
    if not realtime_csv_path.exists():
        raise FileNotFoundError(f"Missing {REALTIME_CSV_NAME} inside: {trial_dir}")

    images_dir = trial_dir / MATCHED_IMAGES_DIR_NAME
    if not images_dir.exists():
        raise FileNotFoundError(f"Missing {MATCHED_IMAGES_DIR_NAME}/ inside: {trial_dir}")

    model_path = resolve_path(DEFAULT_MODEL_PATH, [trial_dir, script_dir])
    if not model_path.exists():
        raise FileNotFoundError(f"YOLO model not found: {model_path}")

    p_path = resolve_path(DEFAULT_P_MATRIX_PATH, [trial_dir, script_dir])
    if not p_path.exists():
        raise FileNotFoundError(f"P matrix file not found: {p_path}")

    out_csv_path = trial_dir / OFFLINE_CSV_NAME
    annotated_dir = trial_dir / OFFLINE_ANNOTATED_DIR_NAME
    annotated_dir.mkdir(exist_ok=True)
    out_video_path = trial_dir / OFFLINE_VIDEO_NAME

    print(f"\n[INFO] Trial folder: {trial_dir}")
    print(f"[INFO] Realtime CSV: {realtime_csv_path}")
    print(f"[INFO] Images folder: {images_dir}")
    print(f"[INFO] YOLO model: {model_path}")
    print(f"[INFO] P matrix: {p_path}")
    print(f"[INFO] Offline CSV output: {out_csv_path}")
    print(f"[INFO] Annotated output: {annotated_dir}")

    P = np.loadtxt(p_path).astype(float)
    if P.shape != (3, 4):
        raise ValueError(f"P matrix must be 3x4. Got {P.shape}")
    C_cam = camera_center_from_P(P)
    print(f"[INFO] Camera center from P: {C_cam}")

    with open(realtime_csv_path, "r", newline="") as f:
        rows = list(csv.DictReader(f))
    if not rows:
        raise RuntimeError("Realtime CSV has no rows.")

    print(f"[INFO] Annotated video will be written pp-style at fixed {ANNOTATED_VIDEO_OUTPUT_FPS:.1f} FPS")

    print("[INFO] Loading YOLO model...")
    model = YOLO(str(model_path), task="pose")
    device_arg = None
    if TRY_CUDA:
        try:
            model.to("cuda")
            device_arg = "cuda"
            print("[INFO] YOLO using CUDA")
        except Exception:
            print("[WARN] CUDA unavailable or failed. Using default device.")

    write_csv_header(out_csv_path)

    kf = OfflineSwingTwistKF()
    last_kf_time_ref = [None]
    twist_zero_state = {"offset": None, "buffer": []}
    annotated_items = []
    start_time_process = time.time()

    valid_images = 0
    detected_count = 0
    error_count = 0

    for i, old_row in enumerate(rows):
        img_path = find_image_for_row(trial_dir, images_dir, old_row)
        if img_path is None or not img_path.exists():
            out_row = {k: np.nan for k in HEADER}
            out_row.update({
                "saved_index": as_int(old_row.get("saved_index"), i),
                "source_frame_index": as_int(old_row.get("source_frame_index"), -1),
                "elapsed_s": as_float(old_row.get("elapsed_s")),
                "detected": 0,
                "matched_image_path": old_row.get("matched_image_path", ""),
                "error_msg": "Could not find matched image",
            })
            append_csv_row(out_csv_path, out_row)
            error_count += 1
            print(f"[WARN] {i+1}/{len(rows)} missing image for saved_index={out_row['saved_index']}")
            continue

        valid_images += 1
        print(f"[YOLO+STATE] {i+1}/{len(rows)} {img_path.name}")

        out_row, annotated = process_one_row(
            old_row=old_row,
            img_path=img_path,
            model=model,
            P=P,
            C_cam=C_cam,
            device_arg=device_arg,
            kf=kf,
            last_kf_time_ref=last_kf_time_ref,
            twist_zero_state=twist_zero_state,
            start_time_process=start_time_process,
            processed_count=i,
        )

        if int(out_row.get("detected", 0) or 0) == 1:
            detected_count += 1
        if str(out_row.get("error_msg", "")):
            error_count += 1

        append_csv_row(out_csv_path, out_row)

        annotated_name = f"offline_{as_int(out_row.get('saved_index'), i):06d}_{img_path.name}"
        annotated_path = annotated_dir / annotated_name
        cv2.imwrite(str(annotated_path), annotated)
        annotated_items.append((annotated_path, get_elapsed_value(out_row)))

    if SAVE_ANNOTATED_VIDEO:
        print("[INFO] Writing annotated video using pp.py-style timestamp reconstruction...")
        make_annotated_video_pp_style(annotated_items, out_video_path, ANNOTATED_VIDEO_OUTPUT_FPS)

    print("\n================ DONE ================")
    print(f"Rows in realtime CSV:       {len(rows)}")
    print(f"Images found/processed:     {valid_images}")
    print(f"Offline detected rows:      {detected_count}")
    print(f"Rows with errors/warnings:  {error_count}")
    print(f"Twist zero offset:          {twist_zero_state['offset']}")
    print(f"Offline CSV saved to:       {out_csv_path}")
    print(f"Annotated frames saved to:  {annotated_dir}")
    if SAVE_ANNOTATED_VIDEO:
        print(f"Annotated video saved to:   {out_video_path}")
    print("======================================")


if __name__ == "__main__":
    main()
